# mpesa-daraja rail service (work04) configuration — env only. Daraja credentials are SECRETS:
# inject via env/KMS, never commit. The devnet shared tokens below are well-known (not secrets).

DARAJA_SERVICE_PORT=8083

# Safaricom Daraja sandbox.
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_PASSKEY=
DARAJA_SANDBOX=true

# Devnet/e2e: stub the Daraja client (synthetic STK responses, no live Safaricom calls). Never prod.
DARAJA_STUB=false

# The public URL Daraja POSTs STK results to (this service's /daraja/callback, token-protected).
DARAJA_CALLBACK_URL=http://localhost:8083/daraja/callback?t=devnet-callback-token
DARAJA_CALLBACK_TOKEN=devnet-callback-token

# The Go adapter core to forward rail-neutral callbacks to (+ the shared internal token).
ADAPTER_CORE_URL=http://localhost:8082
MPESA_ADAPTER_INTERNAL_TOKEN=devnet-internal-token

DARAJA_LOG_LEVEL=info
