# mpesa-adapter CORE (work04) configuration — 12-factor, env only. Copy to .env for local runs.
# The keys below are WELL-KNOWN DEVNET VALUES (not secrets). In production inject real secrets via
# env/KMS. Daraja credentials live in the Node rail service (daraja-service/.env), NOT here.

MPESA_ADAPTER_HTTP_ADDR=:8082
MPESA_ADAPTER_REDIS_URL=redis://localhost:6379/0

# The proof-validator (work03) this adapter broadcasts signed proofs to.
MPESA_ADAPTER_PROOF_VALIDATOR_URL=http://localhost:8081

# The Node.js Daraja rail service (OAuth + STK push + raw callback parsing).
MPESA_ADAPTER_DARAJA_SERVICE_URL=http://localhost:8083

# Shared secret for the internal core↔rail hops (core→rail /stk, rail→core /v1/callbacks/mpesa).
MPESA_ADAPTER_INTERNAL_TOKEN=devnet-internal-token

# The adapter's P-256 proof-signing key (D scalar hex). Its public key MUST be in the validator's
# PROOF_VALIDATOR_TRUSTED_PUBKEYS. The devnet key below derives pubkey 04e63cbe…317d (address
# 0x8aa53f84cd347c2709531511fe7651b05b4734cb) — the key the proof-validator already trusts.
MPESA_ADAPTER_SIGNER_KEY=3f7a1c0d9e8b6a5f4d3c2b1a09f8e7d6c5b4a3928170615243f5e6d7c8b9a0f1

# Default receiver shortcode used when /v1/charges omits one (A.1: the per-charge value is always
# the RECEIVER's shortcode; there is no LinkMint-owned collection account anywhere).
MPESA_ADAPTER_DEFAULT_SHORTCODE=174379

MPESA_ADAPTER_CORRELATION_TTL_SECONDS=3600
MPESA_ADAPTER_IDEMPOTENCY_TTL_SECONDS=86400
MPESA_ADAPTER_HTTP_TIMEOUT_SECONDS=10
MPESA_ADAPTER_LOG_LEVEL=info
