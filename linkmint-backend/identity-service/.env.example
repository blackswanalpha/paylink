# identity-service configuration — all config is env-only (12-factor). Copy to .env for local dev.
# NEVER commit a real .env or any secret (see .gitignore). Secrets are marked [SECRET].

# ── HTTP ──
IDENTITY_HTTP_HOST=0.0.0.0
IDENTITY_HTTP_PORT=8090
IDENTITY_LOG_LEVEL=INFO
IDENTITY_SERVICE_NAME=identity-service

# ── Persistence (shares the Postgres instance; owns the `identity` schema) ──
IDENTITY_DATABASE_URL=postgresql+psycopg://paylink:paylink@localhost:5432/paylink
IDENTITY_REDIS_URL=redis://localhost:6379/0

# ── JWT (RS256). Leave the keys blank for local dev — an ephemeral RSA-2048 keypair is generated
# at startup. In prod, inject a PKCS#8 PEM private key via env/KMS; the public key feeds the JWKS
# endpoint and the gateway's RS256 consumer (GATEWAY_JWT_RS256_PUBLIC_KEY). ──
IDENTITY_JWT_ISSUER=linkmint-identity
IDENTITY_JWT_AUDIENCE=linkmint
# [SECRET] IDENTITY_JWT_PRIVATE_KEY_PEM=
# IDENTITY_JWT_PUBLIC_KEY_PEM=
IDENTITY_ACCESS_TOKEN_TTL_SECONDS=3600
IDENTITY_REFRESH_TOKEN_TTL_SECONDS=2592000

# ── Password / API-key hashing (argon2id) ──
IDENTITY_ARGON2_TIME_COST=3
IDENTITY_ARGON2_MEMORY_COST_KIB=65536
IDENTITY_ARGON2_PARALLELISM=4

# ── MFA secret-at-rest encryption (KMS stand-in). 32 bytes as hex/base64; ephemeral if unset. ──
# [SECRET] IDENTITY_MFA_ENCRYPTION_KEY=

# ── Auth hardening ──
IDENTITY_AUTH_FAILED_THRESHOLD=5

# ── OAuth (stub + seam). oauth_fake=true → deterministic local fake provider (no creds, testable).
# Set false + the per-provider creds below for real Google/Apple/GitHub (NOT verified locally). ──
IDENTITY_OAUTH_FAKE=true
# IDENTITY_OAUTH_GOOGLE_CLIENT_ID=
# [SECRET] IDENTITY_OAUTH_GOOGLE_CLIENT_SECRET=
# IDENTITY_OAUTH_GOOGLE_REDIRECT_URI=
# IDENTITY_OAUTH_APPLE_CLIENT_ID=
# [SECRET] IDENTITY_OAUTH_APPLE_CLIENT_SECRET=
# IDENTITY_OAUTH_APPLE_REDIRECT_URI=
# IDENTITY_OAUTH_GITHUB_CLIENT_ID=
# [SECRET] IDENTITY_OAUTH_GITHUB_CLIENT_SECRET=
# IDENTITY_OAUTH_GITHUB_REDIRECT_URI=

# ── Events (Kafka/SQS transport deferred to work15) ──
# The durable outbox is the identity.identity_events table. log = structured line | noop = silent.
IDENTITY_EVENT_PUBLISHER_MODE=log

# ── Idempotency ──
IDENTITY_IDEMPOTENCY_TTL_SECONDS=86400
