# api-gateway configuration — all config is env-only (12-factor). Copy to .env for local dev.
# NEVER commit a real .env or any secret (see .gitignore). The rendered /kong/kong.yml is the only
# place secrets materialize at runtime and it is git-ignored.

# ── Upstreams (compose hostnames) ──
GATEWAY_PAYLINK_SERVICE_URL=http://paylink-service:8000
GATEWAY_PAYMENT_ORCHESTRATOR_URL=http://payment-orchestrator:8080

# ── JWT (users) ──
# Dev validates HS256 tokens whose `iss` == GATEWAY_JWT_ISSUER, signed with GATEWAY_JWT_DEV_SECRET.
# The caller's on-chain address is read from the GATEWAY_JWT_CREATOR_ADDR_CLAIM claim.
# PROD (work09): register identity-service's RS256 public key as the jwt_secret instead (config-only);
# dynamic JWKS is a follow-up.
GATEWAY_JWT_ISSUER=linkmint-dev
GATEWAY_JWT_DEV_SECRET=devsecret-change-me
GATEWAY_JWT_CREATOR_ADDR_CLAIM=creator_addr

# ── API key (partners) ──
# MVP single sample partner credential (a real, rotatable key store is deferred). custom_id is the
# partner's on-chain creator address (injected downstream as X-Creator-Addr).
GATEWAY_PARTNER_API_KEY=devpartnerkey-change-me
GATEWAY_PARTNER_CREATOR_ADDR=0x00000000000000000000000000000000000000bb

# ── Rate limiting (Redis-backed) ──
GATEWAY_RATE_LIMIT_PER_MINUTE=100
GATEWAY_REDIS_HOST=redis
GATEWAY_REDIS_PORT=6379

# ── Kong runtime (native) ──
KONG_DATABASE=off
KONG_PROXY_LISTEN=0.0.0.0:8088
KONG_ADMIN_LISTEN=127.0.0.1:8001   # admin bound to localhost — never expose
KONG_STATUS_LISTEN=0.0.0.0:8100    # /metrics (prometheus plugin) + /status
KONG_LOG_LEVEL=notice
