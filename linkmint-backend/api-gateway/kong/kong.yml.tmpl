# LinkMint api-gateway — Kong DB-less declarative config (work05, ADR-008).
#
# This is a TEMPLATE: `${GATEWAY_*}` placeholders are rendered by `envsubst` at container start
# (see ../docker-entrypoint.sh) so all config comes from the environment (12-factor). The rendered
# /kong/kong.yml is NOT committed (git-ignored) and is the only place a secret materializes.
#
# Single authenticated ingress:
#   /v1/paylinks*       -> paylink-service        (auth required)
#   /v1/payments*       -> payment-orchestrator   (auth required)
#   /v1/escrows*        -> escrow-manager         (auth required; work20)
#   /v1/notifications*  -> notification-service   (auth required; FE work07 inbox)
#   anything else       -> 404 (LinkMint envelope)
#
# Auth: a request passes if it carries EITHER a valid JWT (Authorization: Bearer ...) OR a valid
# partner API key (X-API-Key). Both auth plugins fall back to the shared `anonymous` consumer on
# failure; the serverless `access` function below then rejects the anonymous consumer with 401.
#
# The serverless (post-function) plugin does the two things no bundled OSS plugin can express
# declaratively: (1) inject a trustworthy X-Creator-Addr (and, for JWT callers, X-User-Id from the
# verified token's `sub` — work12 Flow E compliance gate) while stripping any client-supplied ones
# (ADR-006 anti-spoofing), and (2) rewrite every >=400 response into the LinkMint error envelope
# {"error":{code,message,details,trace_id}}.

_format_version: "3.0"
_transform: true

services:
  # ── paylink-service (work01) ───────────────────────────────────────────────────────────────
  - name: paylink-service
    url: ${GATEWAY_PAYLINK_SERVICE_URL}
    retries: 2
    connect_timeout: 2000
    read_timeout: 10000
    write_timeout: 10000
    routes:
      - name: paylinks
        paths: ["/v1/paylinks"]
        strip_path: false
        preserve_host: false
        plugins:
          - name: jwt
            config:
              anonymous: 11111111-1111-1111-1111-111111111111
              key_claim_name: iss
              claims_to_verify: ["exp"]
              # Header-only: never accept the token via ?jwt= or a cookie (avoids credential leak
              # into URLs/logs and the upstream hop).
              uri_param_names: []
              cookie_names: []
              run_on_preflight: true
          - name: key-auth
            config:
              anonymous: 11111111-1111-1111-1111-111111111111
              key_names: ["X-API-Key"]
              # Header-only + let Kong scrub the key before the upstream hop (defense in depth on
              # top of the post-function's clear_header).
              key_in_header: true
              key_in_query: false
              key_in_body: false
              hide_credentials: true
              run_on_preflight: true
      # Catch-all lives under this service but never proxies — request-termination short-circuits.
      - name: catch-all
        paths: ["/"]
        strip_path: false
        plugins:
          - name: request-termination
            config:
              status_code: 404
              message: "no route matched"

  # ── payment-orchestrator (work02) ──────────────────────────────────────────────────────────
  - name: payment-orchestrator
    url: ${GATEWAY_PAYMENT_ORCHESTRATOR_URL}
    retries: 2
    connect_timeout: 2000
    read_timeout: 10000
    write_timeout: 10000
    routes:
      - name: payments
        paths: ["/v1/payments"]
        strip_path: false
        preserve_host: false
        plugins:
          - name: jwt
            config:
              anonymous: 11111111-1111-1111-1111-111111111111
              key_claim_name: iss
              claims_to_verify: ["exp"]
              # Header-only: never accept the token via ?jwt= or a cookie (avoids credential leak
              # into URLs/logs and the upstream hop).
              uri_param_names: []
              cookie_names: []
              run_on_preflight: true
          - name: key-auth
            config:
              anonymous: 11111111-1111-1111-1111-111111111111
              key_names: ["X-API-Key"]
              # Header-only + let Kong scrub the key before the upstream hop (defense in depth on
              # top of the post-function's clear_header).
              key_in_header: true
              key_in_query: false
              key_in_body: false
              hide_credentials: true
              run_on_preflight: true

  # ── escrow-manager (work20) ────────────────────────────────────────────────────────────────
  # Conditional release/refund. Authenticated like paylinks/payments: jwt OR key-auth, and the
  # post-function injects the trustworthy X-Creator-Addr the service scopes/authorizes by.
  - name: escrow-manager
    url: ${GATEWAY_ESCROW_SERVICE_URL}
    retries: 2
    connect_timeout: 2000
    read_timeout: 10000
    write_timeout: 10000
    routes:
      - name: escrows
        paths: ["/v1/escrows"]
        strip_path: false
        preserve_host: false
        plugins:
          - name: jwt
            config:
              anonymous: 11111111-1111-1111-1111-111111111111
              key_claim_name: iss
              claims_to_verify: ["exp"]
              # Header-only: never accept the token via ?jwt= or a cookie (avoids credential leak
              # into URLs/logs and the upstream hop).
              uri_param_names: []
              cookie_names: []
              run_on_preflight: true
          - name: key-auth
            config:
              anonymous: 11111111-1111-1111-1111-111111111111
              key_names: ["X-API-Key"]
              # Header-only + let Kong scrub the key before the upstream hop (defense in depth on
              # top of the post-function's clear_header).
              key_in_header: true
              key_in_query: false
              key_in_body: false
              hide_credentials: true
              run_on_preflight: true

  # ── notification-service (work14 inbox / FE work07) ──────────────────────────────────────────
  - name: notification-service
    url: ${GATEWAY_NOTIFICATION_SERVICE_URL}
    retries: 2
    connect_timeout: 2000
    read_timeout: 10000
    write_timeout: 10000
    routes:
      - name: notifications
        paths: ["/v1/notifications"]
        strip_path: false
        preserve_host: false
        plugins:
          - name: jwt
            config:
              anonymous: 11111111-1111-1111-1111-111111111111
              key_claim_name: iss
              claims_to_verify: ["exp"]
              uri_param_names: []
              cookie_names: []
              run_on_preflight: true
          - name: key-auth
            config:
              anonymous: 11111111-1111-1111-1111-111111111111
              key_names: ["X-API-Key"]
              key_in_header: true
              key_in_query: false
              key_in_body: false
              hide_credentials: true
              run_on_preflight: true

  # ── identity / merchant / compliance / admin / audit (work08 — additive, PASS-THROUGH) ────────
  # These services authenticate the caller themselves by verifying the RS256 token identity-service
  # issues (iss=linkmint-identity); they do NOT read X-Creator-Addr. So unlike the routes above they
  # carry NO jwt/key-auth plugin: the gateway forwards Authorization untouched and the service is the
  # authority. The post-function `access` block already early-returns for any route whose name is not
  # paylinks/payments/notifications, so it neither strips Authorization nor injects X-Creator-Addr on
  # these routes — exactly what RS256 self-verification needs. Public auth endpoints (register/login/
  # refresh) work because nothing here requires a credential; authenticated routes 401 in-service.
  # The global error-envelope + correlation-id + rate-limit plugins still apply.

  # identity-service (work09): auth (public + authed), users, organizations, sessions.
  - name: identity-service
    url: ${GATEWAY_IDENTITY_SERVICE_URL}
    retries: 2
    connect_timeout: 2000
    read_timeout: 10000
    write_timeout: 10000
    routes:
      - name: identity
        paths: ["/v1/auth", "/v1/users", "/v1/organizations", "/v1/sessions"]
        strip_path: false
        preserve_host: false

  # merchant-onboarding (work10): onboard, documents, bank-accounts, contracts, fee-tier.
  - name: merchant-onboarding
    url: ${GATEWAY_MERCHANT_SERVICE_URL}
    retries: 2
    connect_timeout: 2000
    read_timeout: 10000
    write_timeout: 10000
    routes:
      - name: merchants
        paths: ["/v1/merchants"]
        strip_path: false
        preserve_host: false

  # compliance-risk (work12): compliance status + KYC sessions (callbacks are HMAC-gated in-service).
  - name: compliance-risk
    url: ${GATEWAY_COMPLIANCE_SERVICE_URL}
    retries: 2
    connect_timeout: 2000
    read_timeout: 10000
    write_timeout: 10000
    routes:
      - name: compliance
        paths: ["/v1/compliance", "/v1/kyc"]
        strip_path: false
        preserve_host: false

  # admin-backoffice (work11): ops search + entity drill-down (RS256 + MFA + scope enforced in-service).
  - name: admin-backoffice
    url: ${GATEWAY_ADMIN_SERVICE_URL}
    retries: 2
    connect_timeout: 2000
    read_timeout: 10000
    write_timeout: 10000
    routes:
      - name: admin
        paths: ["/v1/admin"]
        strip_path: false
        preserve_host: false

  # audit-log-service (work13): READS ONLY at the edge. The POST intake is internal (X-Internal-Token)
  # and must not be reachable from the public ingress, so the route matches GET only — a POST falls
  # through to the catch-all 404.
  - name: audit-log-service
    url: ${GATEWAY_AUDIT_SERVICE_URL}
    retries: 2
    connect_timeout: 2000
    read_timeout: 10000
    write_timeout: 10000
    routes:
      - name: audit-log
        paths: ["/v1/audit-log"]
        methods: ["GET"]
        strip_path: false
        preserve_host: false

  # fee-pricing-service (work21): quoting, FX rates, tiers, merchant pricing. PASS-THROUGH (RS256
  # self-verify in-service; the merchant-pricing route is namespaced under /v1/pricing to avoid the
  # /v1/merchants prefix collision with merchant-onboarding). The /v1/internal/* surface is NOT
  # routed here — it falls through to the catch-all 404 (trusted-network only).
  - name: fee-pricing-service
    url: ${GATEWAY_FEE_PRICING_SERVICE_URL}
    retries: 2
    connect_timeout: 2000
    read_timeout: 10000
    write_timeout: 10000
    routes:
      - name: fee-pricing
        paths: ["/v1/pricing", "/v1/fx"]
        strip_path: false
        preserve_host: false

consumers:
  # Shared anonymous fallback — selected by the auth plugins when no valid credential is presented.
  - id: 11111111-1111-1111-1111-111111111111
    username: anonymous

  # Dev user (JWT / HS256). The dev token's `iss` must equal GATEWAY_JWT_ISSUER (the jwt_secret key).
  # The on-chain address is taken from the token's creator-addr claim; custom_id is only a fallback.
  - id: 22222222-2222-2222-2222-222222222222
    username: dev-user
    custom_id: "0x00000000000000000000000000000000000000aa"
    jwt_secrets:
      - key: "${GATEWAY_JWT_ISSUER}"
        algorithm: HS256
        secret: "${GATEWAY_JWT_DEV_SECRET}"

  # Sample partner (API key). MVP key store = this declarative credential (env-sourced). A real
  # partner-key store with rotation/revocation is deferred (follow-up backlog item).
  - id: 33333333-3333-3333-3333-333333333333
    username: partner-acme
    custom_id: "${GATEWAY_PARTNER_CREATOR_ADDR}"
    keyauth_credentials:
      - key: "${GATEWAY_PARTNER_API_KEY}"

  # identity-service RS256 (work09 — ADDITIVE seam, left commented so `kong config parse` stays green
  # while the key is unprovisioned locally; identity generates an ephemeral keypair at startup). To
  # activate end-to-end RS256 at the gateway: uncomment this consumer and set GATEWAY_JWT_RS256_ISSUER
  # (== IDENTITY_JWT_ISSUER, e.g. linkmint-identity) + GATEWAY_JWT_RS256_PUBLIC_KEY (identity's public
  # PEM, served at /v1/auth/.well-known/jwks.json). The HS256 dev consumer above is left intact — the
  # `jwt` plugin picks the credential by the token's `iss` claim, so both token types validate. Remove
  # the HS256 dev secret at the full prod cutover (alg-confusion hygiene). Dynamic JWKS fetch = follow-up.
  # - id: 44444444-4444-4444-4444-444444444444
  #   username: identity-rs256
  #   jwt_secrets:
  #     - key: "${GATEWAY_JWT_RS256_ISSUER}"
  #       algorithm: RS256
  #       rsa_public_key: "${GATEWAY_JWT_RS256_PUBLIC_KEY}"

plugins:
  # Correlation id: reuse an inbound X-Request-Id or generate one; echo it back on the response and
  # forward it downstream (the other services key their structured logs off the same header).
  - name: correlation-id
    config:
      header_name: X-Request-Id
      generator: uuid
      echo_downstream: true

  # Basic rate limiting, keyed by the authenticated consumer (falls back to IP), backed by the
  # shared Redis. Kong sets Retry-After on the 429; the envelope function normalizes the body.
  - name: rate-limiting
    config:
      minute: ${GATEWAY_RATE_LIMIT_PER_MINUTE}
      policy: redis
      limit_by: consumer
      fault_tolerant: true
      redis:
        host: ${GATEWAY_REDIS_HOST}
        port: ${GATEWAY_REDIS_PORT}

  # Prometheus metrics on the Status API listener (KONG_STATUS_LISTEN; :8100).
  - name: prometheus
    config:
      status_code_metrics: true

  # The bespoke logic (single global post-function — runs AFTER the auth plugins in each phase).
  - name: post-function
    config:
      # ACCESS: inject X-Creator-Addr + strip spoofed/credential headers + require auth.
      access:
        - |
          -- Anti-spoofing: the client may NEVER set these on ANY route; the gateway is authoritative.
          -- Stripped before the route check so a spoofed header can't ride through to a work08
          -- pass-through upstream either (those services ignore X-Creator-Addr, but defense-in-depth).
          kong.service.request.clear_header("X-Creator-Addr")
          kong.service.request.clear_header("X-Partner-Id")
          kong.service.request.clear_header("X-User-Id")

          local route = kong.router.get_route()
          local rn = route and route.name or ""
          -- Only the authenticated /v1 routes carry gateway-injected identity. The work08 pass-through
          -- routes (identity/merchant/compliance/admin/audit) self-verify the forwarded bearer token,
          -- so the gateway neither requires a credential nor injects X-Creator-Addr for them; the
          -- catch-all (404) route is likewise skipped.
          if rn ~= "paylinks" and rn ~= "payments" and rn ~= "notifications" and rn ~= "escrows" then
            return
          end

          -- Require authentication. Auth plugins fall through to the anonymous consumer (no
          -- credential) on any failure; reject that here.
          local cred = kong.client.get_credential()
          if not cred then
            kong.service.request.clear_header("Authorization")
            kong.service.request.clear_header("X-API-Key")
            return kong.response.exit(401, { message = "missing or invalid credentials" })
          end

          -- Resolve the caller's identity: the on-chain address (JWT claim first, else the
          -- consumer's custom_id) and the user id (JWT `sub`). The payload decode below does NOT
          -- verify the signature — trust comes from the jwt plugin having authenticated this
          -- request, so it is gated on the credential being a jwt_secrets row (those carry
          -- `algorithm`; key-auth credentials don't). Without the gate, a valid API key plus a
          -- forged Bearer token would inject attacker-chosen identity (auth is OR-composed). An
          -- API-key partner therefore never gets an X-User-Id and resolves via custom_id below.
          local creator_addr
          local user_id
          local auth = kong.request.get_header("Authorization")
          if auth and cred.algorithm ~= nil then
            local token = auth:match("^[Bb]earer%s+(.+)$")
            if token then
              local payload_b64 = token:match("^[^.]+%.([^.]+)%.")
              if payload_b64 then
                payload_b64 = payload_b64:gsub("-", "+"):gsub("_", "/")
                local pad = (4 - (#payload_b64 % 4)) % 4
                if pad > 0 then payload_b64 = payload_b64 .. string.rep("=", pad) end
                local json = ngx.decode_base64(payload_b64)
                if json then
                  local claims = require("cjson.safe").decode(json)
                  if type(claims) == "table" then
                    if claims["${GATEWAY_JWT_CREATOR_ADDR_CLAIM}"] then
                      creator_addr = tostring(claims["${GATEWAY_JWT_CREATOR_ADDR_CLAIM}"])
                    end
                    if type(claims.sub) == "string" and claims.sub ~= "" then
                      user_id = claims.sub
                    end
                  end
                end
              end
            end
          end
          if not creator_addr then
            local consumer = kong.client.get_consumer()
            if consumer and consumer.custom_id and consumer.custom_id ~= "" then
              creator_addr = consumer.custom_id
            end
          end

          -- Don't leak credentials to the upstream now that identity is resolved.
          kong.service.request.clear_header("Authorization")
          kong.service.request.clear_header("X-API-Key")

          if creator_addr and creator_addr ~= "" then
            kong.service.request.set_header("X-Creator-Addr", string.lower(creator_addr))
          end
          -- work12 Flow E: paylink-service evaluates the above-threshold KYC/risk gate only when
          -- the gateway supplies the authenticated user id; absence means the gate is skipped.
          if user_id then
            kong.service.request.set_header("X-User-Id", user_id)
          end
      # HEADER_FILTER: flag error responses; capture the trace id; switch to chunked JSON.
      header_filter:
        - |
          local status = kong.response.get_status()
          if status >= 400 then
            ngx.ctx.lm_envelope = true
            ngx.ctx.lm_status = status
            ngx.ctx.lm_trace_id = kong.request.get_header("X-Request-Id")
              or kong.response.get_header("X-Request-Id") or ""
            kong.response.clear_header("Content-Length")
            kong.response.set_header("Content-Type", "application/json; charset=utf-8")
          end
      # BODY_FILTER: rewrite >=400 bodies into the LinkMint envelope, preserving upstream envelopes.
      body_filter:
        - |
          if not ngx.ctx.lm_envelope then return end
          local cjson = require("cjson.safe")
          local chunk, eof = ngx.arg[1], ngx.arg[2]
          local buf = ngx.ctx.lm_buf or ""
          if chunk and chunk ~= "" then buf = buf .. chunk end
          ngx.ctx.lm_buf = buf
          if not eof then ngx.arg[1] = nil; return end

          local status = ngx.ctx.lm_status or 500
          local codes = {
            [400]="BAD_REQUEST",[401]="UNAUTHORIZED",[403]="FORBIDDEN",[404]="NOT_FOUND",
            [405]="METHOD_NOT_ALLOWED",[406]="NOT_ACCEPTABLE",[408]="REQUEST_TIMEOUT",
            [409]="CONFLICT",[413]="PAYLOAD_TOO_LARGE",[414]="URI_TOO_LONG",
            [415]="UNSUPPORTED_MEDIA_TYPE",[429]="RATE_LIMITED",[500]="INTERNAL_ERROR",
            [502]="BAD_GATEWAY",[503]="SERVICE_UNAVAILABLE",[504]="UPSTREAM_TIMEOUT",
          }

          local existing = cjson.decode(buf)
          if type(existing) == "table" and type(existing.error) == "table" and existing.error.code then
            -- Upstream already returned a LinkMint envelope — pass through unchanged.
            ngx.arg[1] = buf
            ngx.arg[2] = true
            return
          end

          local message
          if type(existing) == "table" and existing.message ~= nil then
            message = tostring(existing.message)
          else
            message = codes[status] or "error"
          end
          local code = codes[status] or "ERROR"
          local trace_id = ngx.ctx.lm_trace_id or ""
          ngx.arg[1] = string.format(
            '{"error":{"code":%s,"message":%s,"details":{},"trace_id":%s}}',
            cjson.encode(code), cjson.encode(message), cjson.encode(trace_id))
          ngx.arg[2] = true
