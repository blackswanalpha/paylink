# compliance-risk configuration — all config is env-only (12-factor). Copy to .env for local dev.
# NEVER commit a real .env or any secret (see .gitignore). Secrets are marked [SECRET].

# ── HTTP ──
COMPLIANCE_HTTP_HOST=0.0.0.0
COMPLIANCE_HTTP_PORT=8093
COMPLIANCE_LOG_LEVEL=INFO
COMPLIANCE_SERVICE_NAME=compliance-risk

# ── Persistence (shares the Postgres instance; owns the `compliance` schema) ──
COMPLIANCE_DATABASE_URL=postgresql+psycopg://paylink:paylink@localhost:5432/paylink
COMPLIANCE_REDIS_URL=redis://localhost:6379/0

# ── JWT (RS256). compliance-risk is a verifier-only CONSUMER of identity-service's tokens; it never
# issues. Set COMPLIANCE_JWT_PUBLIC_KEY_PEM to identity's SubjectPublicKeyInfo PEM (served at
# identity's /v1/auth/.well-known/jwks.json). When unset, an ephemeral public key is generated at
# startup so the verifier constructs — but NO real token will verify (a warning is logged). ──
COMPLIANCE_JWT_ISSUER=linkmint-identity
COMPLIANCE_JWT_AUDIENCE=linkmint
# COMPLIANCE_JWT_PUBLIC_KEY_PEM=

# ── KYC provider. stub = in-process fake (MVP/tests default) | http = real vendor drop-in
# (Jumio/Smile/Onfido — follow-up). COMPLIANCE_KYC_PROVIDER_URL is the upstream base for `http`. ──
COMPLIANCE_KYC_PROVIDER=stub
# COMPLIANCE_KYC_PROVIDER_URL=
COMPLIANCE_KYC_VALIDITY_DAYS=365

# ── KYC callback HMAC secrets, per provider: "<provider>:secret;<provider2>:secret". The
# /v1/kyc/callbacks/{provider} route verifies X-Signature (HMAC-SHA256 over the raw body) against
# the matching secret. ──
# [SECRET] COMPLIANCE_CALLBACK_SECRETS=stub:devnet-callback-secret

# ── Internal endpoint defense-in-depth (ADR-009). /v1/risk/evaluate takes no JWT (trusted network);
# when this is set it additionally requires a constant-time X-Internal-Token match, else it allows. ──
# [SECRET] COMPLIANCE_INTERNAL_SHARED_SECRET=

# ── Provider-ref-at-rest encryption (KMS stand-in). 32 bytes as hex/base64; ephemeral if unset.
# Envelopes kyc_records.provider_ref. NEVER persist/log/return/emit raw PII. ──
# [SECRET] COMPLIANCE_PROVIDER_ENCRYPTION_KEY=

# ── Risk knobs (env-tunable thresholds; all consumed by the pure risk engine) ──
COMPLIANCE_TIER1_CEILING=50000
# Empty = +Infinity (tier 2 has no per-tx ceiling).
COMPLIANCE_TIER2_CEILING=
COMPLIANCE_AML_CUMULATIVE_THRESHOLD=150000
COMPLIANCE_AML_WINDOW_HOURS=720
COMPLIANCE_VELOCITY_BLOCK_24H=50
COMPLIANCE_VELOCITY_REVIEW_24H=20
COMPLIANCE_VELOCITY_REVIEW_1H=10
COMPLIANCE_SCORE_BLOCK_THRESHOLD=0.8
COMPLIANCE_SCORE_REVIEW_THRESHOLD=0.5

# ── Events (Kafka/SQS transport deferred to work15) ──
# The durable outbox is the compliance.compliance_events table. log = structured line | noop = silent.
COMPLIANCE_EVENT_PUBLISHER_MODE=log

# ── Idempotency ──
COMPLIANCE_IDEMPOTENCY_TTL_SECONDS=86400
