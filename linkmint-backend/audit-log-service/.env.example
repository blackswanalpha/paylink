# audit-log-service (work13) — 12-factor configuration. All values have env overrides.

AUDIT_HTTP_ADDR=:8094
AUDIT_DATABASE_URL=postgres://paylink:paylink@localhost:5432/paylink?sslmode=disable
AUDIT_REDIS_URL=redis://localhost:6379/0

# Intake gate (ADR-009 mTLS stand-in). Set to require a constant-time X-Internal-Token on
# POST /v1/audit-log; leave empty to rely on the trusted network only.
AUDIT_INTERNAL_SHARED_SECRET=

# Read-endpoint auth (RS256). Set the identity-service public key PEM to verify admin/compliance
# JWTs in-service; leave empty to trust the gateway (no in-service verification).
AUDIT_JWT_PUBLIC_KEY_PEM=
AUDIT_JWT_ISSUER=
AUDIT_JWT_AUDIENCE=
AUDIT_READER_ROLES=admin,compliance

AUDIT_IDEMPOTENCY_TTL_SECONDS=86400
# Toggle the NATS audit.intake consumer (work15 seam; no-op stub until then).
AUDIT_INTAKE_ENABLED=false
AUDIT_LOG_LEVEL=info
