# admin-backoffice configuration (ADMIN_* — 12-factor). Copy to .env for local dev.

ADMIN_HTTP_PORT=8092
ADMIN_LOG_LEVEL=INFO

# Persistence (shared Postgres `admin` schema; Redis for readiness/Phase-2).
ADMIN_DATABASE_URL=postgresql+psycopg://paylink:paylink@localhost:5432/paylink
ADMIN_REDIS_URL=redis://localhost:6379/0

# JWT (RS256, verify-only). Set to identity-service's public PEM in prod (matches its signer).
ADMIN_JWT_ISSUER=linkmint-identity
ADMIN_JWT_AUDIENCE=linkmint
# ADMIN_JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Upstream read APIs (the console aggregates these over the internal network).
ADMIN_IDENTITY_SERVICE_URL=http://localhost:8090
ADMIN_MERCHANT_SERVICE_URL=http://localhost:8091
ADMIN_PAYLINK_SERVICE_URL=http://localhost:8000
ADMIN_PAYMENT_ORCHESTRATOR_URL=http://localhost:8080

# Audit sink: log (one JSON line per access — work13 drop-in) | noop.
ADMIN_AUDIT_SINK_MODE=log

# Local-dev scope grants (NOT for prod — prod grants live in admin.staff).
# Format: "<sub>:scope,scope;<sub2>:scope". Example grants one user superuser:
# ADMIN_DEV_STAFF_GRANTS=00000000-0000-0000-0000-000000000000:superuser
ADMIN_DEV_STAFF_GRANTS=
