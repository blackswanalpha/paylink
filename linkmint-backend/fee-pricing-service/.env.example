# fee-pricing-service (work21) — 12-factor config. All values are PRICING_* env vars.
# Copy to .env for local dev; secrets default to unset (ephemeral dev material at startup).

PRICING_HTTP_HOST=0.0.0.0
PRICING_HTTP_PORT=8097
PRICING_LOG_LEVEL=INFO

# Shared Postgres (own `pricing` schema) + Redis (idempotency cache /0 + FX hot cache).
PRICING_DATABASE_URL=postgresql+psycopg://paylink:paylink@localhost:5432/paylink
PRICING_REDIS_URL=redis://localhost:6379/0

# JWT (RS256, verify-only) — identity-service's public key. Unset → ephemeral dev key (no real token verifies).
PRICING_JWT_ISSUER=linkmint-identity
PRICING_JWT_AUDIENCE=linkmint
# PRICING_JWT_PUBLIC_KEY_PEM=

# Platform-admin gate for /v1/pricing/tiers — comma-separated user_roles allowed (default: admin).
PRICING_ADMIN_USER_ROLES=admin

# Event bus (work15). "log"/"noop" use the in-process publisher; "kafka" drains the outbox relay.
PRICING_EVENT_PUBLISHER_MODE=log
PRICING_EVENT_CONSUMER_ENABLED=false
KAFKA_BROKERS=

# FX provider: "static" (deterministic env rates) or "http" (live provider seam). 60s Redis cache.
PRICING_FX_PROVIDER=static
PRICING_FX_CACHE_TTL_SECONDS=60
PRICING_FX_STATIC_RATES=USD:KES=129.50,EUR:KES=140.00,KES:KES=1
# Optional fallback rates used when the provider returns nothing (same format).
PRICING_FX_FALLBACK_RATES=

# Monthly platform-fee invoice sweeper (a lifespan task; generation is idempotent per merchant+period).
PRICING_INVOICE_SWEEP_ENABLED=true
PRICING_INVOICE_SWEEP_INTERVAL_SECONDS=3600

# Trusted-network gate for /v1/internal/* (ADR-009 X-Internal-Token). Unset → no token required (dev).
# PRICING_INTERNAL_SHARED_SECRET=devnet-internal-token

# Optional accrual-from-events seam (consume chain.paylink.verified → accrual). Default OFF.
PRICING_ACCRUAL_FROM_EVENTS=false

# A.6 ledger-posting seam — OFF by default (per-service posting deferred in work16).
PRICING_LEDGER_POSTING_ENABLED=false

# Default settlement currency when a quote request omits one.
PRICING_DEFAULT_CURRENCY=KES

# work18 — OpenTelemetry (no-op until the OTLP endpoint is set).
OTEL_SERVICE_NAME=fee-pricing-service
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
