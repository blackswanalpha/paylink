# merchant-onboarding configuration — all config is env-only (12-factor). Copy to .env for local dev.
# NEVER commit a real .env or any secret (see .gitignore). Secrets are marked [SECRET].

# ── HTTP ──
MERCHANT_HTTP_HOST=0.0.0.0
MERCHANT_HTTP_PORT=8091
MERCHANT_LOG_LEVEL=INFO
MERCHANT_SERVICE_NAME=merchant-onboarding

# ── Persistence (shares the Postgres instance; owns the `merchant` schema) ──
MERCHANT_DATABASE_URL=postgresql+psycopg://paylink:paylink@localhost:5432/paylink
MERCHANT_REDIS_URL=redis://localhost:6379/0

# ── JWT (RS256). merchant-onboarding is a verifier-only CONSUMER of identity-service's tokens; it
# never issues. Set MERCHANT_JWT_PUBLIC_KEY_PEM to identity's SubjectPublicKeyInfo PEM (served at
# identity's /v1/auth/.well-known/jwks.json). When unset, an ephemeral public key is generated at
# startup so the verifier constructs — but NO real token will verify (a warning is logged). ──
MERCHANT_JWT_ISSUER=linkmint-identity
MERCHANT_JWT_AUDIENCE=linkmint
# MERCHANT_JWT_PUBLIC_KEY_PEM=

# ── Bank-account-ref-at-rest encryption (KMS stand-in). 32 bytes as hex/base64; ephemeral if unset.
# This envelopes the bank `account_details` into the `account_ref` column. Rotating it re-encrypts
# bank_accounts (follow-up). NEVER persist/log/return/emit the plaintext account details. ──
# [SECRET] MERCHANT_BANK_ENCRYPTION_KEY=

# ── Documents object store. local = filesystem (dev/test default) | s3 = AWS S3 (follow-up). The DB
# stores only the s3_key; the bytes live in the object store. ──
MERCHANT_OBJECT_STORE_MODE=local
MERCHANT_LOCAL_OBJECT_STORE_DIR=/tmp/merchant-documents
MERCHANT_MAX_DOCUMENT_BYTES=10485760
# MERCHANT_S3_BUCKET=
# MERCHANT_S3_REGION=
# MERCHANT_S3_ENDPOINT_URL=
# MERCHANT_S3_PREFIX=merchant-documents

# ── Onboarding policy ──
# Phase 1 is single-country (Kenya). Comma-separated ISO 3166-1 alpha-2 allowlist.
MERCHANT_ALLOWED_COUNTRIES=KE
# Activation preconditions for decide(approve|reinstate) → ACTIVE (env-gated so unit tests can
# exercise the bare state machine).
MERCHANT_REQUIRE_VERIFIED_BANK_FOR_ACTIVE=true
MERCHANT_REQUIRE_CONTRACT_FOR_ACTIVE=true

# ── Events (Kafka/SQS transport deferred to work15) ──
# The durable outbox is the merchant.merchant_events table. log = structured line | noop = silent.
MERCHANT_EVENT_PUBLISHER_MODE=log

# ── Idempotency ──
MERCHANT_IDEMPOTENCY_TTL_SECONDS=86400
