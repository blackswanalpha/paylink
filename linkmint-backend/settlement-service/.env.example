# settlement-service configuration (12-factor: env only). Copy to .env for local runs.
# No secrets belong in this file beyond local dev credentials.

SETTLEMENT_HTTP_ADDR=:8101

# PostgreSQL DSN (owns the "settlement" schema; also runs the shared "ledger" migrations, work16).
SETTLEMENT_DATABASE_URL=postgres://paylink:paylink@localhost:5432/paylink?sslmode=disable

# Redis (Idempotency-Key store, 24h TTL).
SETTLEMENT_REDIS_URL=redis://localhost:6379/0

SETTLEMENT_LOG_LEVEL=info
SETTLEMENT_IDEMPOTENCY_TTL_SECONDS=86400

# Domain-event publisher (work15): "log" records publish intent; "kafka" produces settlement.*/payout.* to the bus.
SETTLEMENT_EVENT_PUBLISHER_MODE=log
# Bus consumers (chain.paylink.verified, chain.fee.collected, merchant.*, refund.clawback.requested).
SETTLEMENT_EVENT_CONSUMER_ENABLED=true
KAFKA_BROKERS=

# Payout scheduler: closes due settlements (T+1 cutoff) and instructs payouts.
SETTLEMENT_SCHEDULE_ENABLED=true
SETTLEMENT_SCHEDULE_INTERVAL_SECONDS=30

# Settlement aggregation defaults (multi-currency is Phase 3 — one settlement currency for the MVP).
SETTLEMENT_CURRENCY=KES
# T+1 cutoff timezone applied to the on-chain verified timestamp when no merchant tz is known.
SETTLEMENT_DEFAULT_TZ=Africa/Nairobi
# Per-currency minimum net payout in minor units ("CCY:minor;CCY:minor"). Below this, a settlement
# stays open and carries forward. Empty => no minimum (every closed settlement pays out).
SETTLEMENT_MIN_PAYOUT=KES:10000
# Optional platform-fee basis points charged on gross (A.5 — kept separate from the chain fee).
# 0 (default) means settlement records only the chain fee from chain.fee.collected.
SETTLEMENT_PLATFORM_FEE_BPS=0

# Shared secret guarding the internal rail-file ingest endpoint (POST /settlements/files/ingest).
# Empty in dev => the endpoint is open locally; set in any deployed environment (trusted-network only).
SETTLEMENT_INGEST_TOKEN=

# Dev-only fallback for the gateway-injected X-Creator-Addr header (the caller's authenticated
# on-chain address = the merchant settlement key). Leave empty in any deployed environment: without
# a header and without this fallback, merchant-scoped routes return 401.
SETTLEMENT_DEV_CREATOR_ADDR=
