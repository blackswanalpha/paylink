# payment-orchestrator configuration (12-factor: env only). Copy to .env for local runs.
# No secrets belong in this file beyond local dev credentials.

PAYMENT_HTTP_ADDR=:8080

# PostgreSQL DSN (owns the "payment" schema).
PAYMENT_DATABASE_URL=postgres://paylink:paylink@localhost:5432/paylink?sslmode=disable

# Redis (Idempotency-Key store, 24h TTL).
PAYMENT_REDIS_URL=redis://localhost:6379/0

# lVM node: JSON-RPC for authoritative PayLink status, WebSocket datastream for live events.
PAYMENT_CHAIN_RPC_URL=http://localhost:8545/
PAYMENT_CHAIN_WS_URL=ws://localhost:8545/ws

# paylink-service (PayLink record owner, work01).
PAYMENT_PAYLINK_SERVICE_URL=http://localhost:8000

# Registered MPesa rail adapter (work04). Config-only registry: logged at boot; the orchestrator
# does not call it (rail stays an opaque routing label). Leave empty if the adapter isn't deployed.
PAYMENT_ADAPTER_MPESA_URL=http://localhost:8082

PAYMENT_LOG_LEVEL=info
PAYMENT_IDEMPOTENCY_TTL_SECONDS=86400
PAYMENT_CHAIN_EVENTS_ENABLED=true
PAYMENT_HTTP_TIMEOUT_SECONDS=10
