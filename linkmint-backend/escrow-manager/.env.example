# escrow-manager configuration (12-factor: env only). Copy to .env for local runs.
# No secrets belong in this file beyond local dev credentials.

ESCROW_HTTP_ADDR=:8098

# PostgreSQL DSN (owns the "escrow" schema).
ESCROW_DATABASE_URL=postgres://paylink:paylink@localhost:5432/paylink?sslmode=disable

# Redis (Idempotency-Key store, 24h TTL).
ESCROW_REDIS_URL=redis://localhost:6379/0

ESCROW_LOG_LEVEL=info
ESCROW_IDEMPOTENCY_TTL_SECONDS=86400

# Domain-event publisher (work15): "log" records publish intent; "kafka" produces escrow.* to the bus.
ESCROW_EVENT_PUBLISHER_MODE=log
# Bus consumer for chain.paylink.verified (funding truth). Requires KAFKA_BROKERS when enabled.
ESCROW_EVENT_CONSUMER_ENABLED=true
KAFKA_BROKERS=

# Sweeper: releases due funded time_locks and refunds timed-out escrows.
ESCROW_SWEEP_ENABLED=true
ESCROW_SWEEP_INTERVAL_SECONDS=10

# Default escrow timeout when the create request omits timeout_at (24h).
ESCROW_DEFAULT_TIMEOUT_SECONDS=86400

# Dev-only fallback for the gateway-injected X-Creator-Addr header. Leave empty in any deployed
# environment: without a header and without this fallback, mutating routes return 401.
ESCROW_DEV_CREATOR_ADDR=
