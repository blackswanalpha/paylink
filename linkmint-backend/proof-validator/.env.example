# proof-validator (work03) configuration — 12-factor, env only. Copy to .env for local runs.
# The keys below are WELL-KNOWN DEVNET VALUES (not secrets). In production, inject real secrets via
# env/KMS and set PROOF_VALIDATOR_AUTO_STAKE=false (the validator is staked out-of-band).

PROOF_VALIDATOR_HTTP_ADDR=:8081
PROOF_VALIDATOR_DATABASE_URL=postgres://paylink:paylink@localhost:5432/paylink?sslmode=disable
PROOF_VALIDATOR_REDIS_URL=redis://localhost:6379/0
PROOF_VALIDATOR_CHAIN_RPC_URL=http://localhost:8545/

# The validator's own P-256 signing key (D scalar hex). In the devnet this is the same key the
# chain node runs with (--privkey), so the proof-validator IS the single active validator.
# Address: 0xb186e935537a49fdfd394ab0b0110c5479ab51d2
PROOF_VALIDATOR_SIGNER_MODE=service_key
PROOF_VALIDATOR_CHAIN_SIGNER_KEY=b71c71a67e1177ad4e901695e1b4b9ee17ae16c6668d313eac2f96dbcda3f291

# Trusted proof-signer public keys (uncompressed P-256 hex, comma-separated). A proof is accepted
# only if its proof_signature verifies against one of these. The devnet value is the adapter key
# used by the e2e test (private 3f7a…a0f1, address 0x8aa53f84cd347c2709531511fe7651b05b4734cb).
PROOF_VALIDATOR_TRUSTED_PUBKEYS=04e63cbe3984eae5834516e4af2e8e7fa88ce497f68bdcacf95a8fdaf9db4b02efa0ebcb964a1a74ec3d8c748b1e32986788f6c9a4aac39f0b79ac359801a5317d

# Cross-check the proof against the on-chain PayLink (status/amount/expiry) before broadcasting.
PROOF_VALIDATOR_PAYLINK_CROSSCHECK=true

# Devnet bootstrap: self-stake on startup so the signer becomes an active validator (so a
# single-validator devnet can reach quorum and settle). Disable in production.
PROOF_VALIDATOR_AUTO_STAKE=true
PROOF_VALIDATOR_STAKE_AMOUNT=0
PROOF_VALIDATOR_AUTO_STAKE_TIMEOUT_SECONDS=30
PROOF_VALIDATOR_AUTO_STAKE_POLL_MS=1000

PROOF_VALIDATOR_LOG_LEVEL=info
PROOF_VALIDATOR_IDEMPOTENCY_TTL_SECONDS=86400
PROOF_VALIDATOR_HTTP_TIMEOUT_SECONDS=10
