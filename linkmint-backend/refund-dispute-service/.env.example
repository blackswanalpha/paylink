# refund-dispute-service (work22) — 12-factor config. All values are REFUND_* env vars.
# Copy to .env for local dev; secrets default to unset (ephemeral dev material at startup).

REFUND_HTTP_HOST=0.0.0.0
REFUND_HTTP_PORT=8100
REFUND_LOG_LEVEL=INFO

# Shared Postgres (own `refund` schema) + Redis (idempotency cache /0 + consumer dedupe).
REFUND_DATABASE_URL=postgresql+psycopg://paylink:paylink@localhost:5432/paylink
REFUND_REDIS_URL=redis://localhost:6379/0

# JWT (RS256, verify-only) — identity-service's public key. Unset → ephemeral dev key (no real token verifies).
REFUND_JWT_ISSUER=linkmint-identity
REFUND_JWT_AUDIENCE=linkmint
# REFUND_JWT_PUBLIC_KEY_PEM=

# Platform-admin gate — comma-separated user_roles that may act across orgs (default: admin).
REFUND_ADMIN_USER_ROLES=admin

# Event bus (work15). "log"/"noop" use the in-process publisher; "kafka" drains the outbox relay.
REFUND_EVENT_PUBLISHER_MODE=log
REFUND_EVENT_CONSUMER_ENABLED=false
KAFKA_BROKERS=

# Upstream services — refund eligibility (orchestrator) + original-amount fallback (paylink-service).
REFUND_PAYMENT_ORCHESTRATOR_URL=http://localhost:8080
REFUND_PAYLINK_SERVICE_URL=http://localhost:8000
REFUND_UPSTREAM_TIMEOUT_SECONDS=5.0

# Amount validation — "strict" (502 when the original amount is unresolvable) or "lenient" (accept
# the caller amount; merchant approval is then the gate). Prod runs strict; dev compose runs lenient.
REFUND_AMOUNT_VALIDATION=strict

# Rail reversal is instruction-only (A.1 — no adapter supports reversal yet). In dev, the sweeper can
# simulate PROCESSING→COMPLETED after the threshold below.
REFUND_REVERSAL_SIMULATE=false
REFUND_SIMULATE_COMPLETE_AFTER_SECONDS=10

# Dispute evidence window (the rail-imposed deadline). Provider webhooks may override per-dispute.
REFUND_DISPUTE_EVIDENCE_WINDOW_HOURS=168

# Provider webhook HMAC secrets: "<provider>:secret;<provider2>:secret".
REFUND_WEBHOOK_SECRETS=stub:devnet-dispute-secret

# Clawback coordination (work23 settlement) — "event" writes the refund.clawback.requested outbox
# row settlement will consume; "noop" disables (tests).
REFUND_CLAWBACK_MODE=event

# Sweeper (a lifespan task): expires overdue disputes + (dev) simulates refund completion.
REFUND_SWEEP_ENABLED=true
REFUND_SWEEP_INTERVAL_SECONDS=30

# A.6 ledger-posting seam — OFF by default (settlement work23 is the canonical writer).
REFUND_LEDGER_POSTING_ENABLED=false

REFUND_DEFAULT_CURRENCY=KES

# work18 — OpenTelemetry (no-op until the OTLP endpoint is set).
OTEL_SERVICE_NAME=refund-dispute-service
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
