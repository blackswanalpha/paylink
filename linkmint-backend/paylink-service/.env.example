# paylink-service configuration — all config is env-only (12-factor). Copy to .env for local dev.
# NEVER commit a real .env or any secret (see .gitignore).

# ── HTTP ──
PAYLINK_HTTP_HOST=0.0.0.0
PAYLINK_HTTP_PORT=8000
PAYLINK_LOG_LEVEL=INFO
PAYLINK_SERVICE_NAME=paylink-service

# ── Postgres (async driver: postgresql+psycopg://) ──
PAYLINK_DATABASE_URL=postgresql+psycopg://paylink:paylink@localhost:5432/paylink

# ── Redis (idempotency store) ──
PAYLINK_REDIS_URL=redis://localhost:6379/0

# ── lVM chain JSON-RPC ──
PAYLINK_CHAIN_RPC_URL=http://localhost:8545/
PAYLINK_CHAIN_SUBMIT_ENABLED=true

# Signer seam. signer_mode=service_key signs TxCreatePayLink/TxCancelPayLink with the key below
# (NIST P-256, hex of the big-endian D scalar — same format as paylinkd --privkey).
# signer_mode=unsigned sends an empty signature (the chain does not yet verify signatures; ADR-005).
# Leave the key blank in service_key mode to auto-generate an ephemeral dev key at startup.
PAYLINK_SIGNER_MODE=service_key
PAYLINK_CHAIN_SIGNER_KEY=

# ── Domain defaults ──
PAYLINK_DEFAULT_CURRENCY=PLN
# Above this minor-unit amount a future compliance/KYC gate (work12) would apply. Seam only today.
PAYLINK_AMOUNT_KYC_THRESHOLD=100000000

# ── Events (Kafka/SQS transport deferred to work15) ──
# The durable outbox is the paylink.paylink_events table (always written by the service).
# This only selects the live-notification seam: log = structured log line | noop = silent.
PAYLINK_EVENT_PUBLISHER_MODE=log
