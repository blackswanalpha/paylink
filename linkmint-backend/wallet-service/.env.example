# wallet-service (work24) — 12-factor configuration. No secrets are committed; production injects
# real values via the environment. Defaults make a local `go run` work against the compose names.

# HTTP listen address.
WALLET_HTTP_ADDR=:8102

# PostgreSQL DSN (wallet schema). One schema per service; no cross-schema FKs.
WALLET_DATABASE_URL=postgres://paylink:paylink@localhost:5432/paylink?sslmode=disable

# Log level: debug|info|warn|error.
WALLET_LOG_LEVEL=info

# lVM JSON-RPC endpoint. Used read-through for live balance/nonce and for the unsigned-intent nonce.
WALLET_CHAIN_RPC_URL=http://localhost:8545/
WALLET_CHAIN_HTTP_TIMEOUT_SECONDS=5

# Fallback chain id reported by /staking/intent when the chain is unreachable. The service also
# fetches the live id via paylink_chainInfo and caches it.
WALLET_CHAIN_ID=paylink-devnet

# Chain indexer (consumes the `chain` topic into the wallet read-side).
WALLET_EVENT_CONSUMER_ENABLED=true
KAFKA_BROKERS=

# How long a read-through balance row is served from cache before re-hitting the chain RPC.
WALLET_BALANCE_CACHE_TTL_SECONDS=5

# Dev-only fallback for the gateway-injected X-Creator-Addr (self-scopes wallet/staking reads).
WALLET_DEV_CREATOR_ADDR=

# work18 — OpenTelemetry export (no-op unless OTEL_EXPORTER_OTLP_ENDPOINT is set).
OTEL_SERVICE_NAME=wallet-service
OTEL_EXPORTER_OTLP_ENDPOINT=
