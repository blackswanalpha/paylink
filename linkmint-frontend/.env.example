# LinkMint demo frontend — copy to .env.local for local dev.
# Values below match the dev defaults wired in the repo's docker-compose.yml.

# ── Server-only (NEVER shipped to the browser) ──────────────────────────────────────────────
# Used by the Next server component to mint a dev HS256 JWT and to proxy /v1 to the gateway.

# Upstream API gateway (Kong) the Next dev server proxies /v1/* to.
LINKMINT_GATEWAY_URL=http://localhost:8088

# Dev JWT (HS256) — must match the gateway's GATEWAY_JWT_* settings (docker-compose.yml).
# DEMO ONLY. Never use a real secret here, and never expose it via a NEXT_PUBLIC_ var.
LINKMINT_JWT_DEV_SECRET=devsecret-change-me
LINKMINT_JWT_ISSUER=linkmint-dev
LINKMINT_JWT_CREATOR_ADDR=0x00000000000000000000000000000000000000bb
LINKMINT_JWT_TTL_SECONDS=3600

# Dev user for the work08 identity smoke card on /dashboard. The server logs this user in against
# identity-service (registering once if needed) to mint a real RS256 token for client.users.me.
# DEMO ONLY — identity-service issues/verifies its own RS256 tokens (it does not accept the HS256
# dev token above). Password must be >= 8 chars.
LINKMINT_DEV_USER_EMAIL=dev+work08@linkmint.local
LINKMINT_DEV_USER_PASSWORD=work08-dev-password

# ── Client (NEXT_PUBLIC_*, embedded in the browser bundle) ──────────────────────────────────

# Optional explicit API base URL for the SDK. Leave empty to use the app's own origin
# (recommended — keeps /v1 same-origin so the Next rewrite proxies it to the gateway).
NEXT_PUBLIC_LINKMINT_BASE_URL=

# Presentational MPesa pay instructions (no funds are collected in-app — A.1 non-custodial).
NEXT_PUBLIC_MPESA_PAYBILL=174379

# Settlement poll interval (ms) for watching the PayLink reach VERIFIED.
NEXT_PUBLIC_SETTLEMENT_POLL_MS=2500

# Create-form defaults (demo convenience).
NEXT_PUBLIC_DEFAULT_CURRENCY=KES
NEXT_PUBLIC_DEFAULT_RECEIVER=0x1111111111111111111111111111111111111111
